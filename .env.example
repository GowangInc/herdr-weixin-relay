# Herdr personal-WeChat relay config. Copy to the plugin config dir as .env.
# Credentials are NOT stored here; QR login writes them to the plugin state dir.

# Local control HTTP port used by thin Herdr plugin commands to talk to the daemon.
HERDR_WEIXIN_PORT=27187

# Optional default inbound Herdr target. The target-current action saves the focused pane/agent instead.
# Forms: agent:<name-or-label>, pane:<pane-id>. Bare values are treated as agent targets.
HERDR_WEIXIN_TARGET=

# Optional comma-separated allow-list of WeChat user ids. Empty accepts any sender.
HERDR_WEIXIN_ALLOW_FROM=

# Optional OMP model role used when creating the WeChat session pane.
HERDR_WEIXIN_MODEL_ROLE=wechat

# Optional override if herdr is not on PATH for the daemon.
HERDR_BIN_PATH=

# Advanced: identity sent in ilink base_info.bot_agent. Keep UA-style tokens.
HERDR_WEIXIN_BOT_AGENT=HerdrWeixinRelay/0.1.0
